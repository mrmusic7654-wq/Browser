```gitignore
# Compiled and binary files
*.class
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Dependencies
node_modules/
venv/
.venv/
__pycache__/
.mypy_cache/
.pytest_cache/
target/
.gradle/

# Build artifacts
dist/
build/

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db
.env
.env.local
*.env.*

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
*.pyo
*.pyd
*.egg-info/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Java specific
*.jar
*.war
*.ear
hs_err_pid*

# Kotlin specific
*.kotlin_metadata
*.kotlin_built

# Android specific
*.apk
*.aab
local.properties
.gradle/
captures/
.externalNativeBuild
.cxx/
.idea/caches
.idea/libraries
.idea/modules.xml
.idea/runConfigurations
.idea/assetWizardSettings.xml
.idea/compiler.xml
.idea/jarRepositories.xml
.idea/misc.xml
.idea/vcs.xml
.idea/workspace.xml
```